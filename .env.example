# API Keys (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEWS_API_KEY=your_news_api_key_here

# Database (auto-configured in Docker; override for local dev outside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/macrosignal

# Redis (auto-configured in Docker; override for local dev outside Docker)
REDIS_URL=redis://localhost:6379/0

# Flask
FLASK_ENV=development

# Frontend API URL (set to /api in production Docker; override for local dev)
VITE_API_URL=http://localhost:5001
